# Supabase Configuration
# Get these values from your Supabase project dashboard at https://app.supabase.com
# Project Settings → API

# Your Supabase project URL (looks like: https://your-project-id.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase project's anon public key (a long JWT string)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# To use this locally:
# 1. Copy this file to .env.local
# 2. Fill in your actual Supabase credentials
# 3. Never commit .env.local to git (it's in .gitignore)
